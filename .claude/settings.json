{
  "agentPushNotifEnabled" : true,
  "alwaysThinkingEnabled" : true,
  "editorMode" : "vim",
  "enabledPlugins" : {
    "figma@claude-plugins-official" : true,
    "gopls-lsp@claude-plugins-official" : true,
    "typescript-lsp@claude-plugins-official" : true
  },
  "env" : {
    "ENABLE_TOOL_SEARCH" : "true"
  },
  "extraKnownMarketplaces" : {
    "a11y-specialist-skills" : {
      "source" : {
        "repo" : "masuP9\/a11y-specialist-skills",
        "source" : "github"
      }
    }
  },
  "hooks" : {
    "Notification" : [
      {
        "hooks" : [
          {
            "command" : "afplay \/System\/Library\/Sounds\/Hero.aiff",
            "type" : "command"
          }
        ],
        "matcher" : ""
      }
    ],
    "PermissionRequest" : [
      {
        "hooks" : [
          {
            "command" : "\"${CLAUDE_CONFIG_DIR:-$HOME\/.claude}\/hooks\/notchi-hook.sh\"",
            "type" : "command"
          }
        ],
        "matcher" : "*"
      }
    ],
    "PostToolUse" : [
      {
        "hooks" : [
          {
            "command" : "\"${CLAUDE_CONFIG_DIR:-$HOME\/.claude}\/hooks\/notchi-hook.sh\"",
            "type" : "command"
          }
        ],
        "matcher" : "*"
      }
    ],
    "PreCompact" : [
      {
        "hooks" : [
          {
            "command" : "\"${CLAUDE_CONFIG_DIR:-$HOME\/.claude}\/hooks\/notchi-hook.sh\"",
            "type" : "command"
          }
        ],
        "matcher" : "auto"
      },
      {
        "hooks" : [
          {
            "command" : "\"${CLAUDE_CONFIG_DIR:-$HOME\/.claude}\/hooks\/notchi-hook.sh\"",
            "type" : "command"
          }
        ],
        "matcher" : "manual"
      }
    ],
    "PreToolUse" : [
      {
        "hooks" : [
          {
            "command" : "afplay \/System\/Library\/Sounds\/Pop.aiff",
            "type" : "command"
          }
        ],
        "matcher" : "*"
      },
      {
        "hooks" : [
          {
            "command" : "\"${CLAUDE_CONFIG_DIR:-$HOME\/.claude}\/hooks\/notchi-hook.sh\"",
            "type" : "command"
          }
        ],
        "matcher" : "*"
      }
    ],
    "SessionEnd" : [
      {
        "hooks" : [
          {
            "command" : "\"${CLAUDE_CONFIG_DIR:-$HOME\/.claude}\/hooks\/notchi-hook.sh\"",
            "type" : "command"
          }
        ]
      }
    ],
    "SessionStart" : [
      {
        "hooks" : [
          {
            "command" : "\"${CLAUDE_CONFIG_DIR:-$HOME\/.claude}\/hooks\/notchi-hook.sh\"",
            "type" : "command"
          }
        ]
      }
    ],
    "Stop" : [
      {
        "hooks" : [
          {
            "command" : "afplay \/System\/Library\/Sounds\/Glass.aiff",
            "type" : "command"
          }
        ]
      },
      {
        "hooks" : [
          {
            "command" : "\"${CLAUDE_CONFIG_DIR:-$HOME\/.claude}\/hooks\/notchi-hook.sh\"",
            "type" : "command"
          }
        ]
      }
    ],
    "SubagentStop" : [
      {
        "hooks" : [
          {
            "command" : "\"${CLAUDE_CONFIG_DIR:-$HOME\/.claude}\/hooks\/notchi-hook.sh\"",
            "type" : "command"
          }
        ]
      }
    ],
    "UserPromptSubmit" : [
      {
        "hooks" : [
          {
            "command" : "\"${CLAUDE_CONFIG_DIR:-$HOME\/.claude}\/hooks\/notchi-hook.sh\"",
            "type" : "command"
          }
        ]
      }
    ]
  },
  "language" : "japanese",
  "permissions" : {
    "allow" : [
      "Bash",
      "Edit",
      "Write",
      "Read",
      "TodoWrite",
      "WebSearch",
      "WebFetch",
      "mcp__pencil",
      "mcp__chrome-devtools__take_screenshot",
      "mcp__chrome-devtools__take_snapshot",
      "mcp__chrome-devtools__list_network_requests",
      "mcp__chrome-devtools__list_pages",
      "mcp__chrome-devtools__get_network_request",
      "Bash(git push:*)"
    ],
    "ask" : [
      "Bash(git push origin main)",
      "Bash(git push origin main:*)",
      "Bash(git push -u origin main)",
      "Bash(git push -u origin main:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git clean -fd:*)",
      "Bash(git branch -D:*)",
      "Bash(rm -rf:*)"
    ],
    "defaultMode" : "auto",
    "deny" : [

    ]
  },
  "skipAutoPermissionPrompt" : true,
  "skipDangerousModePermissionPrompt" : true,
  "spinnerVerbs" : {
    "mode" : "replace",
    "verbs" : [
      "ろーでぃんぐ"
    ]
  },
  "statusLine" : {
    "command" : "bash ~\/.claude\/statusline-command.sh",
    "type" : "command"
  },
  "theme" : "dark",
  "voiceEnabled" : true
}